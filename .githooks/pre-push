#!/bin/sh
# pre-push: build the exe and run the full test suite before pushing.
# Activate: git config core.hooksPath .githooks

echo "Building exe..."
zig build 2>&1
if [ $? -ne 0 ]; then
    echo "Build failed. Fix before pushing."
    exit 1
fi

echo "Running tests..."
zig build test --summary all 2>&1
if [ $? -ne 0 ]; then
    echo "Tests failed. Fix before pushing."
    exit 1
fi
